# AI MIDI 생성 시스템 환경 변수 설정
# 이 파일을 .env로 복사하고 실제 값으로 변경하세요

# ===========================================
# LLM Provider API Keys
# ===========================================

# Anthropic Claude API Key (필수 - 기본 프로바이더)
ANTHROPIC_API_KEY="your_anthropic_api_key_here"

# OpenAI API Key (GPT-4용)
OPENAI_API_KEY="your_openai_api_key_here"

# EXAONE API Key (LG AI Research)
EXAONE_API_KEY="your_exaone_api_key_here"
EXAONE_BASE_URL="https://api.exaone.ai/v1"

# ===========================================
# LLM Provider 기본 설정
# ===========================================

# 기본 사용할 LLM Provider (claude, openai, exaone)
DEFAULT_LLM_PROVIDER="claude"

# 최대 토큰 수 (100-8000)
MAX_TOKENS=4000

# 생성 온도 (0.0-2.0, 낮을수록 일관성 높음)
TEMPERATURE=0.7

# ===========================================
# 데이터베이스 설정
# ===========================================

# 데이터베이스 URL (SQLite 기본)
DATABASE_URL="sqlite:///./data/ai_songwriting.db"

# SQL 쿼리 로그 출력 여부
ECHO_SQL=false

# ===========================================
# MIDI 생성 설정
# ===========================================

# MIDI 파일 출력 디렉토리
MIDI_OUTPUT_DIR="output/midi"

# 생성된 모듈 저장 디렉토리
GENERATED_MODULES_DIR="generated_modules"

# 스니펫 라이브러리 디렉토리
SNIPPETS_LIBRARY_DIR="my_snippets"

# MIDI 해상도 (120, 240, 480, 960)
MIDI_TICKS_PER_QUARTER=480

# 기본 벨로시티 (1-127)
MIDI_DEFAULT_VELOCITY=80

# 미리보기 오디오 생성 여부
GENERATE_PREVIEW=true

# 미리보기 오디오 형식 (wav, mp3)
PREVIEW_FORMAT="wav"

# 미리보기 오디오 샘플 레이트
PREVIEW_SAMPLE_RATE=44100

# ===========================================
# 로깅 설정
# ===========================================

# 로그 레벨 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL="INFO"

# 로그 파일 경로
LOG_FILE="logs/ai_songwriting.log"

# ===========================================
# 개발 설정
# ===========================================

# 디버그 모드 (개발 시에만 true)
DEBUG=false
